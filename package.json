{
  "name": "vibrantsocial",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate resolve --rolled-back 20260320_schema_drift_fix 2>/dev/null; prisma migrate resolve --rolled-back 20260401_add_user_statuses_likes 2>/dev/null; prisma migrate deploy && prisma generate && next build",
    "db:migrate": "prisma migrate deploy",
    "db:setup": "./scripts/setup-local-db.sh",
    "db:reset": "prisma migrate reset --force",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "generate-bg-thumbs": "tsx scripts/generate-bg-thumbnails.ts"
  },
