generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  pendingEmail  String?
  image         String?

  // VibrantSocial profile fields
  username    String? @unique
  displayName String?
  bio         String?
  avatar      String?

  // Profile picture frame (premium feature)
  profileFrameId String?

  // Custom username font
  usernameFont String?

  // Profile theme colors
  profileBgColor        String?
  profileTextColor      String?
  profileLinkColor      String?
  profileSecondaryColor String?
  profileContainerColor String?

  // Profile background image
  profileBgImage      String?
  profileBgRepeat     String?
  profileBgAttachment String?
  profileBgSize       String?
  profileBgPosition   String?

  // Sparklefall (raining emoji) settings
  sparklefallEnabled     Boolean @default(false)
  sparklefallPreset      String?
  sparklefallSparkles    String?
  sparklefallColors      String?
  sparklefallInterval    Int?
  sparklefallWind        Float?
  sparklefallMaxSparkles Int?
  sparklefallMinSize     Int?
  sparklefallMaxSize     Int?

  // Birthday (month/day only, for in-app celebrations)
  birthdayMonth Int?
  birthdayDay   Int?

  // Credentials auth
  passwordHash String?
  dateOfBirth  DateTime?

  // Age verification payment (Stripe)
  ageVerificationPaid     DateTime?
  stripeCheckoutSessionId String?

  // Age verification (AgeChecker.net)
  ageVerified          DateTime?
  ageVerificationUuid  String?
  showGraphicByDefault Boolean   @default(false)
  showNsfwContent      Boolean   @default(false)

  // Subscription tier
  tier                  String    @default("free") // "free" | "premium"
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?
  premiumExpiresAt      DateTime?

  // Stars (interaction points)
  stars      Int     @default(0)
  starsSpent Int     @default(0)

  // Referral program
  referralCode      String    @unique @default(cuid())
  referredById      String?
  referralBonusPaid Boolean   @default(false)
  referredBy        User?     @relation("referrals", fields: [referredById], references: [id])
  referrals         User[]    @relation("referrals")

  // Phone verification
  phoneNumber   String?
  phoneVerified DateTime?

  // Email notification preferences
  emailOnComment        Boolean @default(true)
  emailOnNewChat        Boolean @default(true)
  emailOnMention        Boolean @default(true)
  emailOnFriendRequest  Boolean @default(true)
  emailOnSubscribedPost Boolean @default(true)
  emailOnTagPost        Boolean @default(true)

  // Push notification preferences
  pushEnabled Boolean @default(false)

  // Profile visibility
  isProfilePublic    Boolean @default(true)
  hideWallFromFeed   Boolean @default(false)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastSeenFeedAt DateTime?

  accounts  Account[]
  sessions  Session[]
  posts     Post[]
  comments  Comment[]
  likes     Like[]
  bookmarks Bookmark[]
  reposts   Repost[]
  repostLikes     RepostLike[]
  repostBookmarks RepostBookmark[]
  repostComments  RepostComment[]
  followers    Follow[]       @relation("followers")
  following    Follow[]       @relation("following")
  sentFriendRequests     FriendRequest[] @relation("sentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("receivedFriendRequests")
  bioRevisions BioRevision[]

  // Chat relations
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  sentMessageRequests      MessageRequest[] @relation("sentMessageRequests")
  receivedMessageRequests  MessageRequest[] @relation("receivedMessageRequests")

  // Reactions
  messageReactions MessageReaction[]
  commentReactions CommentReaction[]

  // Notifications
  notificationsReceived Notification[] @relation("notificationTarget")
  notificationsSent     Notification[] @relation("notificationActor")

  // Push subscriptions
  pushSubscriptions PushSubscription[]

  // Content moderation
  quarantinedUploads    QuarantinedUpload[]
  contentViolations     ContentViolation[]
  contentWarnings       Int       @default(0)
  contentStrikes        Int       @default(0)
  suspended             Boolean   @default(false)
  suspendedAt           DateTime?

  // Close friends
  closeFriends  CloseFriend[] @relation("closeFriendOwner")
  closeFriendOf CloseFriend[] @relation("closeFriendTarget")

  // Custom post audiences
  postAudiences PostAudience[]

  // Post subscriptions
  postSubscriptions PostSubscription[] @relation("postSubscriber")
  postSubscribers   PostSubscription[] @relation("postSubscribedTo")

  // Blocks
  blockedUsers Block[]      @relation("blocker")
  blockedBy    Block[]      @relation("blocked")
  phoneBlocks  PhoneBlock[] @relation("phoneBlockBlocker")

  // User lists
  userLists              UserList[]             @relation("userListOwner")
  userListMembers        UserListMember[]       @relation("userListMembership")
  userListSubscriptions  UserListSubscription[] @relation("userListSubscriber")
  userListCollaborations UserListCollaborator[] @relation("userListCollaborator")

  // Tag subscriptions
  tagSubscriptions TagSubscription[]

  // Wall posts (posts from friends on this user's profile)
  wallPosts WallPost[] @relation("wallPosts")

  // AI-generated custom theme presets
  customThemePresets CustomThemePreset[]

  // Linked accounts (multi-account switching)
  linkedAccountGroupId String?
  linkedAccountGroup   LinkedAccountGroup? @relation(fields: [linkedAccountGroupId], references: [id])

  @@index([linkedAccountGroupId])
  @@index([username])
  @@index([displayName])
  @@index([name])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id                 String    @id @default(cuid())
  slug               String?
  content            String    @db.Text
  authorId           String?
  isAuthorDeleted    Boolean   @default(false)
  isSensitive        Boolean   @default(false)
  isNsfw             Boolean   @default(false)
  isGraphicNudity    Boolean   @default(false)
  isCloseFriendsOnly Boolean   @default(false)
  hasCustomAudience  Boolean   @default(false)
  isLoggedInOnly     Boolean   @default(false)
  isPinned           Boolean   @default(false)
  hideLinkPreview    Boolean   @default(false)
  editedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  author        User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  reposts       Repost[]
  notifications     Notification[]
  revisions         PostRevision[]
  tags              PostTag[]
  audience          PostAudience[]
  contentViolations ContentViolation[]
  wallPost          WallPost?

  @@unique([authorId, slug])
  @@index([authorId])
  @@index([createdAt])
}

model Tag {
  id            String            @id @default(cuid())
  name          String            @unique
  isNsfw        Boolean           @default(false)
  createdAt     DateTime          @default(now())
  posts         PostTag[]
  reposts       RepostTag[]
  subscriptions TagSubscription[]
  notifications Notification[]
}

model PostTag {
  id     String @id @default(cuid())
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([tagId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  parentId  String?
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  post          Post               @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?           @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]          @relation("CommentReplies")
  reactions     CommentReaction[]
  notifications Notification[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Repost {
  id                 String   @id @default(cuid())
  postId             String
  userId             String
  content            String?  @db.Text
  isSensitive        Boolean  @default(false)
  isNsfw             Boolean  @default(false)
  isGraphicNudity    Boolean  @default(false)
  isCloseFriendsOnly Boolean  @default(false)
  isPinned           Boolean  @default(false)
  editedAt           DateTime?
  createdAt          DateTime @default(now())

  post Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags            RepostTag[]
  likes           RepostLike[]
  bookmarks       RepostBookmark[]
  comments        RepostComment[]
  notifications   Notification[]

  @@unique([postId, userId])
}

model RepostTag {
  id       String @id @default(cuid())
  repostId String
  tagId    String
  repost   Repost @relation(fields: [repostId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([repostId, tagId])
  @@index([tagId])
}

model RepostLike {
  id        String   @id @default(cuid())
  repostId  String
  userId    String
  createdAt DateTime @default(now())

  repost Repost @relation(fields: [repostId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([repostId, userId])
  @@index([repostId])
}

model RepostBookmark {
  id        String   @id @default(cuid())
  repostId  String
  userId    String
  createdAt DateTime @default(now())

  repost Repost @relation(fields: [repostId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([repostId, userId])
  @@index([repostId])
}

model RepostComment {
  id        String   @id @default(cuid())
  content   String
  repostId  String
  authorId  String
  parentId  String?
  createdAt DateTime @default(now())

  repost  Repost          @relation(fields: [repostId], references: [id], onDelete: Cascade)
  author  User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  RepostComment?  @relation("RepostCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies RepostComment[] @relation("RepostCommentReplies")

  @@index([repostId])
  @@index([authorId])
  @@index([parentId])
}

model BioRevision {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PostRevision {
  id        String   @id @default(cuid())
  postId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// Friend requests

enum FriendRequestStatus {
  PENDING
  ACCEPTED
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  sender   User @relation("sentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId])
}

// Close friends (private list, only visible to the owner)

model CloseFriend {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("closeFriendOwner", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("closeFriendTarget", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
}

// Post subscriptions (subscribe to a user's new posts)

model PostSubscription {
  id             String   @id @default(cuid())
  subscriberId   String
  subscribedToId String
  createdAt      DateTime @default(now())

  subscriber   User @relation("postSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  subscribedTo User @relation("postSubscribedTo", fields: [subscribedToId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, subscribedToId])
  @@index([subscriberId])
  @@index([subscribedToId])
}

// User blocks

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model PhoneBlock {
  id          String   @id @default(cuid())
  blockerId   String
  phoneNumber String
  createdAt   DateTime @default(now())

  blocker User @relation("phoneBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, phoneNumber])
  @@index([phoneNumber])
}

// Tag subscriptions (subscribe to new posts in a tag)

model TagSubscription {
  id                String    @id @default(cuid())
  userId            String
  tagId             String
  frequency         String    @default("immediate") // "immediate" | "digest"
  emailNotification Boolean   @default(false)        // whether to also send email
  lastDigestSentAt  DateTime?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])
}

// Chat models

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  chatEmailSentAt DateTime?
  isAdmin        Boolean   @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String    @db.Text
  mediaUrl       String?
  mediaType      String?
  mediaFileName  String?
  mediaFileSize  Int?
  replyToId      String?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  conversation  Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo       Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       Message[]         @relation("MessageReplies")
  reactions     MessageReaction[]
  notifications Notification[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

enum MessageRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model MessageRequest {
  id         String               @id @default(cuid())
  senderId   String
  receiverId String
  status     MessageRequestStatus @default(PENDING)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  sender   User @relation("sentMessageRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receivedMessageRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId])
}

// Notifications

enum NotificationType {
  LIKE
  COMMENT
  REPLY
  REPOST
  BOOKMARK
  FOLLOW
  REACTION
  MENTION
  FRIEND_REQUEST
  NEW_POST
  TAG_POST
  CONTENT_MODERATION
  REFERRAL_SIGNUP
  STARS_MILESTONE
  LIST_ADD
  LIST_SUBSCRIBE
  LIST_COLLABORATOR_ADD
  WALL_POST
}

model Notification {
  id           String           @id @default(cuid())
  type         NotificationType
  actorId      String
  targetUserId String
  postId       String?
  commentId    String?
  messageId    String?
  repostId     String?
  tagId        String?
  readAt       DateTime?
  createdAt    DateTime         @default(now())

  actor      User     @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser User     @relation("notificationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  message    Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  repost     Repost?  @relation(fields: [repostId], references: [id], onDelete: Cascade)
  tag        Tag?     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([targetUserId, readAt, createdAt])
  @@index([actorId])
}

// Content moderation

model ContentViolation {
  id         String    @id @default(cuid())
  userId     String
  postId     String
  type       String    // "nsfw_unmarked", "hate_speech", "bullying"
  confidence Float
  action     String    // "auto_flagged", "pending_review"
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
}

model QuarantinedUpload {
  id             String   @id @default(cuid())
  userId         String
  classification String
  sha256         String
  fileName       String
  fileSize       Int
  mimeType       String
  ipAddress      String?
  userAgent      String?
  referer        String?
  uploadEndpoint String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Push notifications

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Deleted user archive (for audit/compliance)

model DeletedUser {
  id          String   @id @default(cuid())
  originalId  String   @unique
  email       String?
  username    String?
  displayName String?
  deletedAt   DateTime @default(now())
}

// Linked account groups (multi-account switching)

model LinkedAccountGroup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  members   User[]
}

model PremiumWaitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// User lists (curated feeds)

model UserList {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User                   @relation("userListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       UserListMember[]
  subscriptions UserListSubscription[]
  collaborators UserListCollaborator[]

  @@unique([ownerId, name])
  @@index([ownerId])
}

model UserListMember {
  id        String   @id @default(cuid())
  listId    String
  userId    String
  createdAt DateTime @default(now())

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User     @relation("userListMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([listId])
  @@index([userId])
}

model UserListSubscription {
  id        String   @id @default(cuid())
  listId    String
  userId    String
  createdAt DateTime @default(now())

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User     @relation("userListSubscriber", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([listId])
  @@index([userId])
}

model UserListCollaborator {
  id        String   @id @default(cuid())
  listId    String
  userId    String
  createdAt DateTime @default(now())

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User     @relation("userListCollaborator", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([listId])
  @@index([userId])
}

model PostAudience {
  id     String @id @default(cuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// Wall posts (friend posts on profile)

model WallPost {
  id          String   @id @default(cuid())
  postId      String   @unique
  wallOwnerId String
  status      String   @default("pending") // "pending" | "accepted" | "hidden"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  wallOwner User @relation("wallPosts", fields: [wallOwnerId], references: [id], onDelete: Cascade)

  @@index([wallOwnerId, status])
}

model CustomThemePreset {
  id     String @id @default(cuid())
  userId String
  name   String
  prompt String

  // Light variant
  lightBgColor        String
  lightTextColor      String
  lightLinkColor      String
  lightSecondaryColor String
  lightContainerColor String

  // Dark variant
  darkBgColor        String
  darkTextColor      String
  darkLinkColor      String
  darkSecondaryColor String
  darkContainerColor String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}
