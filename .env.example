# Database - Neon PostgreSQL
#
# Production and staging use separate Neon databases.
# Vercel Preview deployments automatically use the staging DB via environment variables.
# For local staging access, set these to the staging connection strings in .env.local.
#
# Pooled connection (runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct connection (migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Discord OAuth — https://discord.com/developers/applications
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# Vercel Blob — auto-provided when Blob storage is enabled in Vercel dashboard
BLOB_READ_WRITE_TOKEN=""

# Project Arachnid Shield — https://www.projectarachnid.com/en/
ARACHNID_SHIELD_USERNAME=""
ARACHNID_SHIELD_PASSWORD=""

# Upstash Redis — https://console.upstash.com (used for rate limiting & caching)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# AgeChecker.net — https://agechecker.net
AGECHECKER_API_KEY=""
AGECHECKER_SECRET=""

# Anthropic (Claude AI) — https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Web Push — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
