# Database - Neon PostgreSQL
# Pooled connection (runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct connection (migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Discord OAuth — https://discord.com/developers/applications
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# Vercel Blob — auto-provided when Blob storage is enabled in Vercel dashboard
BLOB_READ_WRITE_TOKEN=""

# Project Arachnid Shield — https://www.projectarachnid.com/en/
ARACHNID_SHIELD_USERNAME=""
ARACHNID_SHIELD_PASSWORD=""

# Upstash Redis — https://console.upstash.com (used for rate limiting & caching)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
