<?xml version="1.0" encoding="utf-8"?>
<!--
  Release-safe network policy: no cleartext traffic anywhere. The dev
  cleartext exceptions for localhost / 10.0.2.2 live in
  src/debug/res/xml/network_security_config.xml and only ship in debug
  builds. Play Store submissions must not permit cleartext, so this is
  the file packaged into release AABs.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
