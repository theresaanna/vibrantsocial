<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only cleartext exception: lets `flutter run` hit the Next.js
  dev server on localhost and the Android emulator's host alias
  (10.0.2.2) without TLS. This file is scoped to the debug build type
  via src/debug/ and is NOT packaged into release AABs.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
